class Solution {
    public void duplicateZeros(int[] arr) {
        for (int i = 0; i < arr.length; i++) {
            if (arr[i] == 0) {
                
                // shift everything to the right
                for (int j = arr.length - 1; j > i; j--) {
                    arr[j] = arr[j - 1];
                }

                // duplicate zero
                arr[i + 1] = 0;

                i++; // skip the duplicated zero
            }
        }
    }
}
